    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// --- НОВЫЙ КУСОЧЕК ТУТ ---\n// Достаем курс UAH из узла \"HTTP Request\"\n// Важно: проверь, чтобы узел с курсом назывался именно \"HTTP Request\"\nconst liveRate = $node[\"HTTP Request\"].json[\"rates\"][\"UAH\"]; \n// -------------------------\n\nlet totalRevenue = 0;\nlet totalQuantity = 0;\nlet products = [];\n\nfor (const item of items) {\n  const q = Number(item.json[\"Количество\"]) || 0;\n  const p = Number(item.json[\"Цена_EUR\"]) || 0;\n  \n  totalQuantity += q;\n  \n  // --- ИЗМЕНЕНИЕ ТУТ ---\n  // Вместо 42 теперь используем liveRate\n  totalRevenue += (q * p * liveRate); \n  // -------------------------\n  \n  if (q > 0 && item.json[\"Товар\"]) {\n    products.push(item.json[\"Товар\"]);\n  }\n}\n\nlet uniqueProducts = [...new Set(products)].slice(0, 5).join(\", \");\n\nconst d = new Date();\nconst dateHuman = d.toLocaleDateString('ru-RU');\nconst dateNotion = d.toISOString().split('T')[0];\n\nreturn [\n  {\n    json: {\n      total_revenue: Number(totalRevenue.toFixed(2)), \n      total_quantity: Number(totalQuantity),\n      top_products: uniqueProducts || \"Нет продаж\",\n      date: dateHuman,\n      notion_date: dateNotion,\n      reporte: \"Отчет за \" + dateHuman,\n      // Добавим курс в отчет, чтобы ты видела его в письме!\n      current_rate: liveRate \n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
        48
      ],
      "id": "53c9c62c-8c87-4c7d-b610-67423e563632",
      "name": "Расчеты"
    },
    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "models/gemini-2.5-flash",
          "mode": "list",
          "cachedResultName": "models/gemini-2.5-flash"
        },
        "messages": {
          "values": [
            {
              "content": "=Ты — опытный бизнес-аналитик. Твоя задача — составить краткий и профессиональный отчет по продажам за неделю.\n\nВот данные для анализа:\n- Дата отчета: {{ $json.date }}\n- Общая выручка: {{ $json.total_revenue }} UAH\n- Общее количество проданных товаров: {{ $json.total_quantity }} шт.\n- Список проданных товаров (топ-5): {{ $json.top_products }}\n\nНапиши отчет по следующей структуре:\n1. Краткое резюме (как прошла неделя).\n2. Анализ выручки и спроса.\n3. Мнение о проданных товарах (какие позиции лидеры).\n4. Одна рекомендация для бизнеса (на что обратить внимание на следующей неделе).\n\nПиши на русском языке, тон деловой, но понятный."
            }
          ]
        },
        "builtInTools": {},
        "options": {}
